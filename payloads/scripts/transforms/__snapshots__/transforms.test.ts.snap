exports[`google → anthropic > reasoningRequest > request 1`] = `
{
  "max_tokens": 4096,
  "messages": [
    {
      "content": "Solve this step by step: If a train travels 60 mph for 2 hours, then 80 mph for 1 hour, what's the average speed?",
      "role": "user",
    },
  ],
  "model": "claude-sonnet-4-5-20250929",
}
`;

exports[`google → anthropic > reasoningRequest > response 1`] = `
{
  "candidates": [
    {
      "content": {
        "parts": [
          {
            "text": "# Finding Average Speed

I need to find the average speed for the entire trip.

## Step 1: Calculate distance for each segment

**First segment:**
- Speed = 60 mph
- Time = 2 hours
- Distance = 60 × 2 = 120 miles

**Second segment:**
- Speed = 80 mph
- Time = 1 hour
- Distance = 80 × 1 = 80 miles

## Step 2: Calculate total distance and total time

**Total distance** = 120 + 80 = 200 miles

**Total time** = 2 + 1 = 3 hours

## Step 3: Calculate average speed

Average speed = Total distance ÷ Total time

Average speed = 200 ÷ 3 = **66.67 mph** (or 66⅔ mph)

---

**Answer: The average speed is approximately 66.67 mph**",
          },
        ],
        "role": "model",
      },
      "finishReason": "STOP",
      "index": 0,
    },
  ],
