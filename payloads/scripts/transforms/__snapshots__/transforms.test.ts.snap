exports[`google → responses > reasoningRequest > response 1`] = `
{
  "candidates": [
    {
      "content": {
        "parts": [
          {
            "text": "",
            "thought": true,
          },
        ],
        "role": "model",
      },
      "finishReason": "STOP",
      "index": 0,
    },
    {
      "content": {
        "parts": [
          {
            "text": "Step-by-step:

- Leg 1: distance = speed × time = 60 mph × 2 h = 120 miles
- Leg 2: distance = 80 mph × 1 h = 80 miles
- Total distance = 120 + 80 = 200 miles
- Total time = 2 + 1 = 3 hours
- Average speed = total distance / total time = 200 miles / 3 hours = 200/3 mph ≈ 66.7 mph

Answer: 200/3 mph (about 66.67 mph)",
          },
        ],
        "role": "model",
      },
      "finishReason": "STOP",
      "index": 1,
